{
  "name": "@rubros/db",
  "version": "1.0.0",
  "description": "",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./generated/prisma": {
      "import": "./generated/prisma/index.js",
      "types": "./generated/prisma/index.d.ts"
    },
    "./entities": {
      "import": "./dist/entities/index.js",
      "types": "./dist/entities/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "migrate": "prisma migrate dev",
    "migrate-reset": "prisma migrate reset",
    "generate": "prisma generate",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed/seed.ts",
    "seed-provinces": "tsx prisma/seed/seedProvinces.ts",
    "seed-categories": "tsx prisma/seed/seedCategories.ts",
    "seed-test": "node --expose-gc node_modules/.bin/tsx prisma/seed/seed_test.ts",
    "init-docker": "docker compose up -d",
    "build": "prisma generate && tsc -p tsconfig.json",
    "postbuild": "mkdir -p dist/generated/prisma && cp -r generated/prisma/* dist/generated/prisma/ && mkdir -p ../../apps/mechanic-finder/generated/prisma && cp -r dist/generated/prisma/* ../../apps/mechanic-finder/generated/prisma/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@types/stream-json": "^1.7.8",
    "prisma": "^6.9.0",
    "stream-json": "^1.9.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifiers": true
  }
}
